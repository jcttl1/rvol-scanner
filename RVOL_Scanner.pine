array.set(priceArr, 8,c09), array.set(priceArr, 9,c10), array.set(priceArr,10,c11), array.set(priceArr,11,c12)
array.set(priceArr,12,c13), array.set(priceArr,13,c14), array.set(priceArr,14,c15), array.set(priceArr,15,c16)
array.set(priceArr,16,c17), array.set(priceArr,17,c18), array.set(priceArr,18,c19), array.set(priceArr,19,c20)
array.set(priceArr,20,c21), array.set(priceArr,21,c22), array.set(priceArr,22,c23), array.set(priceArr,23,c24)
array.set(priceArr,24,c25), array.set(priceArr,25,c26), array.set(priceArr,26,c27), array.set(priceArr,27,c28)
array.set(priceArr,28,c29), array.set(priceArr,29,c30), array.set(priceArr,30,c31), array.set(priceArr,31,c32)
array.set(priceArr,32,c33), array.set(priceArr,33,c34), array.set(priceArr,34,c35), array.set(priceArr,35,c36)
array.set(priceArr,36,c37), array.set(priceArr,37,c38), array.set(priceArr,38,c39), array.set(priceArr,39,c40)

array.set(chgArr, 0,pc01), array.set(chgArr, 1,pc02), array.set(chgArr, 2,pc03), array.set(chgArr, 3,pc04)
array.set(chgArr, 4,pc05), array.set(chgArr, 5,pc06), array.set(chgArr, 6,pc07), array.set(chgArr, 7,pc08)
array.set(chgArr, 8,pc09), array.set(chgArr, 9,pc10), array.set(chgArr,10,pc11), array.set(chgArr,11,pc12)
array.set(chgArr,12,pc13), array.set(chgArr,13,pc14), array.set(chgArr,14,pc15), array.set(chgArr,15,pc16)
array.set(chgArr,16,pc17), array.set(chgArr,17,pc18), array.set(chgArr,18,pc19), array.set(chgArr,19,pc20)
array.set(chgArr,20,pc21), array.set(chgArr,21,pc22), array.set(chgArr,22,pc23), array.set(chgArr,23,pc24)
array.set(chgArr,24,pc25), array.set(chgArr,25,pc26), array.set(chgArr,26,pc27), array.set(chgArr,27,pc28)
array.set(chgArr,28,pc29), array.set(chgArr,29,pc30), array.set(chgArr,30,pc31), array.set(chgArr,31,pc32)
array.set(chgArr,32,pc33), array.set(chgArr,33,pc34), array.set(chgArr,34,pc35), array.set(chgArr,35,pc36)
array.set(chgArr,36,pc37), array.set(chgArr,37,pc38), array.set(chgArr,38,pc39), array.set(chgArr,39,pc40)

array.set(nameArr, 0,n01), array.set(nameArr, 1,n02), array.set(nameArr, 2,n03), array.set(nameArr, 3,n04)
array.set(nameArr, 4,n05), array.set(nameArr, 5,n06), array.set(nameArr, 6,n07), array.set(nameArr, 7,n08)
array.set(nameArr, 8,n09), array.set(nameArr, 9,n10), array.set(nameArr,10,n11), array.set(nameArr,11,n12)
array.set(nameArr,12,n13), array.set(nameArr,13,n14), array.set(nameArr,14,n15), array.set(nameArr,15,n16)
array.set(nameArr,16,n17), array.set(nameArr,17,n18), array.set(nameArr,18,n19), array.set(nameArr,19,n20)
array.set(nameArr,20,n21), array.set(nameArr,21,n22), array.set(nameArr,22,n23), array.set(nameArr,23,n24)
array.set(nameArr,24,n25), array.set(nameArr,25,n26), array.set(nameArr,26,n27), array.set(nameArr,27,n28)
array.set(nameArr,28,n29), array.set(nameArr,29,n30), array.set(nameArr,30,n31), array.set(nameArr,31,n32)
array.set(nameArr,32,n33), array.set(nameArr,33,n34), array.set(nameArr,34,n35), array.set(nameArr,35,n36)
array.set(nameArr,36,n37), array.set(nameArr,37,n38), array.set(nameArr,38,n39), array.set(nameArr,39,n40)

// ─── SORT BY SPIKE RATIO (descending — selection sort) ──────────────────────

for i = 0 to SIZE - 1
    array.set(idxArr, i, i)

for i = 0 to SIZE - 2
    int   maxPos = i
    float maxVal = array.get(spikeArr, array.get(idxArr, i))
    for j = i + 1 to SIZE - 1
        float val = array.get(spikeArr, array.get(idxArr, j))
        if val > maxVal
            maxPos := j
            maxVal := val
    if maxPos != i
        int tmp = array.get(idxArr, i)
        array.set(idxArr, i, array.get(idxArr, maxPos))
        array.set(idxArr, maxPos, tmp)

// ─── SIGNAL LEVEL FUNCTIONS ─────────────────────────────────────────────────

getSignalColor(float spike) =>
    spike >= 8.0 ? colExt : spike >= 5.0 ? colVHi : spike >= 3.0 ? colHi : spike >= 2.0 ? colElev : spike >= 1.5 ? colMod : color.gray

getSignalBg(float spike) =>
    spike >= 8.0 ? color.new(colExt,80) : spike >= 5.0 ? color.new(colVHi,82) : spike >= 3.0 ? color.new(colHi,85) : spike >= 2.0 ? color.new(colElev,87) : spike >= 1.5 ? color.new(colMod,90) : color.new(color.gray,95)

getSignalLabel(float spike) =>
    spike >= 8.0 ? "EXTREME" : spike >= 5.0 ? "VERY HIGH" : spike >= 3.0 ? "HIGH" : spike >= 2.0 ? "ELEVATED" : spike >= 1.5 ? "MODERATE" : "—"

// ─── TABLE POSITION ─────────────────────────────────────────────────────────

tablePos = switch tblPos
    "Top Right"     => position.top_right
    "Top Left"      => position.top_left
    "Bottom Right"  => position.bottom_right
    "Bottom Left"   => position.bottom_left
    "Middle Right"  => position.middle_right
    "Middle Left"   => position.middle_left
    => position.top_right

// ─── DETERMINE COLUMN COUNT ─────────────────────────────────────────────────

int numCols = 2  // Ticker + Spike are always shown
if showRank
    numCols += 1
numCols += 1     // Signal column always shown
if showPrice
    numCols += 1
if showChg
    numCols += 1

// ─── BUILD TABLE ────────────────────────────────────────────────────────────

var table scannerTbl = table.new(tablePos, 6, tblRows + 1, border_width = tblBorder)

// Padding helper — adds spaces for column width
pad(string txt) =>
    if colWidth > 0
        int padAmt = math.max(colWidth - str.length(txt), 0)
        string result = txt
        for _p = 1 to padAmt
            result := " " + result
        " " + result + " "
    else
        " " + txt + " "

if barstate.islast
    // --- Header ---
    color hdrBg  = color.new(#1a1d2b, 0)
    color hdrTxt = color.new(#8890a5, 0)

    int col = 0
    if showRank
        table.cell(scannerTbl, col, 0, pad("#"),      text_color=hdrTxt, bgcolor=hdrBg, text_size=txtSize, text_halign=text.align_center)
        col += 1
    table.cell(scannerTbl, col, 0, pad("TICKER"),     text_color=hdrTxt, bgcolor=hdrBg, text_size=txtSize, text_halign=text.align_left)
    col += 1
    table.cell(scannerTbl, col, 0, pad("SPIKE"),      text_color=hdrTxt, bgcolor=hdrBg, text_size=txtSize, text_halign=text.align_center)
    col += 1
    table.cell(scannerTbl, col, 0, pad("SIGNAL"),     text_color=hdrTxt, bgcolor=hdrBg, text_size=txtSize, text_halign=text.align_center)
    col += 1
    if showPrice
        table.cell(scannerTbl, col, 0, pad("PRICE"),  text_color=hdrTxt, bgcolor=hdrBg, text_size=txtSize, text_halign=text.align_right)
        col += 1
    if showChg
        table.cell(scannerTbl, col, 0, pad("CHG%"),   text_color=hdrTxt, bgcolor=hdrBg, text_size=txtSize, text_halign=text.align_right)

    // --- Data Rows ---
    int rowNum = 0
    for i = 0 to SIZE - 1
        if rowNum >= tblRows
            break

        int    idx   = array.get(idxArr, i)
        float  spike = array.get(spikeArr, idx)
        string name  = array.get(nameArr, idx)
        float  price = array.get(priceArr, idx)
        float  chg   = array.get(chgArr, idx)

        if not showNorm and spike < 1.5
            continue

        int    row     = rowNum + 1
        color  sigCol  = getSignalColor(spike)
        color  bgCol   = getSignalBg(spike)
        string sigLbl  = getSignalLabel(spike)
        color  chgCol  = chg >= 0 ? color.new(#00c853,0) : color.new(#ff1744,0)
        string chgSign = chg >= 0 ? "+" : ""
        color  rowBg   = color.new(#131620, 0)
        color  cellBg  = spike >= 1.5 ? bgCol : rowBg

        int c = 0
        if showRank
            table.cell(scannerTbl, c, row, pad(str.tostring(rowNum+1)),                             text_color=color.new(#555e70,0), bgcolor=cellBg, text_size=txtSize, text_halign=text.align_center)
            c += 1
        table.cell(scannerTbl, c, row, pad(name),                                                   text_color=color.new(#dfe2ea,0), bgcolor=cellBg, text_size=txtSize, text_halign=text.align_left)
        c += 1
        table.cell(scannerTbl, c, row, pad(str.tostring(spike,"#.#")+"x"),                          text_color=sigCol,               bgcolor=cellBg, text_size=txtSize, text_halign=text.align_center)
        c += 1
        table.cell(scannerTbl, c, row, pad(sigLbl),                                                 text_color=sigCol,               bgcolor=cellBg, text_size=txtSize, text_halign=text.align_center)
        c += 1
        if showPrice
            table.cell(scannerTbl, c, row, pad("$"+str.tostring(price,"#.##")),                     text_color=color.new(#dfe2ea,0), bgcolor=cellBg, text_size=txtSize, text_halign=text.align_right)
            c += 1
        if showChg
            table.cell(scannerTbl, c, row, pad(chgSign+str.tostring(chg,"#.##")+"%"),               text_color=chgCol,               bgcolor=cellBg, text_size=txtSize, text_halign=text.align_right)

        rowNum += 1

// ─── ALERTS ─────────────────────────────────────────────────────────────────
// Three separate alert conditions:
//   1. Any spike above user-defined threshold (general)
//   2. Very High spikes (5x+)
//   3. Extreme spikes (8x+)
// Each builds a message listing which tickers triggered it.

bool anySpike    = false
bool veryHiSpike = false
bool extremeSpike = false
string alertMsgGeneral  = ""
string alertMsgVeryHigh = ""
string alertMsgExtreme  = ""

for i = 0 to SIZE - 1
    float  sp   = array.get(spikeArr, i)
    string nm   = array.get(nameArr, i)
    float  chgV = array.get(chgArr, i)
    string chgS = chgV >= 0 ? "+" : ""
    string info = nm + " " + str.tostring(sp, "#.#") + "x (" + chgS + str.tostring(chgV, "#.##") + "%) | "

    if sp >= alertThr
        anySpike := true
        alertMsgGeneral += info
    if sp >= 5.0
        veryHiSpike := true
        alertMsgVeryHigh += info
    if sp >= 8.0
        extremeSpike := true
        alertMsgExtreme += info

// General alert — fires at your custom threshold (respects toggle)
alertcondition(alertGeneral and anySpike, title = "RVOL Spike (Custom Threshold)", message = "Volume spike above threshold detected! Open scanner to see details.")

// Very High alert — fires at 5x+ (respects toggle)
alertcondition(alertVeryHigh and veryHiSpike, title = "RVOL VERY HIGH (5x+)", message = "VERY HIGH volume spike (5x+) detected! Possible catalyst/news event.")

// Extreme alert — fires at 8x+ (respects toggle)
alertcondition(alertExtreme and extremeSpike, title = "RVOL EXTREME (8x+)", message = "EXTREME volume spike (8x+) detected! Major event — get to this chart immediately.")

// Hidden plots for alert message placeholders
plot(anySpike     ? array.max(spikeArr) : 0, display = display.none, title = "Max Spike")
plot(veryHiSpike  ? 1 : 0,                   display = display.none, title = "Very High Flag")
plot(extremeSpike ? 1 : 0,                   display = display.none, title = "Extreme Flag")
