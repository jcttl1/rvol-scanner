// ─── DATA FETCH: spike ratio + close + change % ────────────────────────────
// Pine limit is 127 tuple elements. 40 calls × 3 returns = 120. Fits.

getData3() =>
    float avgVol     = ta.sma(volume, lookback)
    float spikeRatio = avgVol > 0 ? volume / avgVol : 0.0
    float changePct  = close[1] != 0 ? (close - close[1]) / close[1] * 100.0 : 0.0
    [spikeRatio, close, changePct]

[sr01,c01,pc01]=request.security(s01,timeframe.period,getData3())
