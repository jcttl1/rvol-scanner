array.set(chgArr,0,pc01),array.set(chgArr,1,pc02),array.set(chgArr,2,pc03),array.set(chgArr,3,pc04)
array.set(chgArr,4,pc05),array.set(chgArr,5,pc06),array.set(chgArr,6,pc07),array.set(chgArr,7,pc08)
array.set(chgArr,8,pc09),array.set(chgArr,9,pc10),array.set(chgArr,10,pc11),array.set(chgArr,11,pc12)
array.set(chgArr,12,pc13),array.set(chgArr,13,pc14),array.set(chgArr,14,pc15),array.set(chgArr,15,pc16)
array.set(chgArr,16,pc17),array.set(chgArr,17,pc18),array.set(chgArr,18,pc19),array.set(chgArr,19,pc20)
array.set(chgArr,20,pc21),array.set(chgArr,21,pc22),array.set(chgArr,22,pc23),array.set(chgArr,23,pc24)
array.set(chgArr,24,pc25),array.set(chgArr,25,pc26),array.set(chgArr,26,pc27),array.set(chgArr,27,pc28)
array.set(chgArr,28,pc29),array.set(chgArr,29,pc30),array.set(chgArr,30,pc31),array.set(chgArr,31,pc32)
array.set(chgArr,32,pc33),array.set(chgArr,33,pc34),array.set(chgArr,34,pc35),array.set(chgArr,35,pc36)
array.set(chgArr,36,pc37),array.set(chgArr,37,pc38),array.set(chgArr,38,pc39),array.set(chgArr,39,pc40)

array.set(nameArr,0,n01),array.set(nameArr,1,n02),array.set(nameArr,2,n03),array.set(nameArr,3,n04)
array.set(nameArr,4,n05),array.set(nameArr,5,n06),array.set(nameArr,6,n07),array.set(nameArr,7,n08)
array.set(nameArr,8,n09),array.set(nameArr,9,n10),array.set(nameArr,10,n11),array.set(nameArr,11,n12)
array.set(nameArr,12,n13),array.set(nameArr,13,n14),array.set(nameArr,14,n15),array.set(nameArr,15,n16)
array.set(nameArr,16,n17),array.set(nameArr,17,n18),array.set(nameArr,18,n19),array.set(nameArr,19,n20)
array.set(nameArr,20,n21),array.set(nameArr,21,n22),array.set(nameArr,22,n23),array.set(nameArr,23,n24)
array.set(nameArr,24,n25),array.set(nameArr,25,n26),array.set(nameArr,26,n27),array.set(nameArr,27,n28)
array.set(nameArr,28,n29),array.set(nameArr,29,n30),array.set(nameArr,30,n31),array.set(nameArr,31,n32)
array.set(nameArr,32,n33),array.set(nameArr,33,n34),array.set(nameArr,34,n35),array.set(nameArr,35,n36)
array.set(nameArr,36,n37),array.set(nameArr,37,n38),array.set(nameArr,38,n39),array.set(nameArr,39,n40)

// ─── DEMO MODE ──────────────────────────────────────────────────────────────

if demoMode
    float[] ds = array.from(14.2,10.5, 8.1,6.8,5.5, 4.7,4.2,3.6,3.3,3.0, 2.7,2.4,2.1,1.9,1.8, 1.6,1.5,1.4,1.3,1.2, 1.1,1.0,0.9,0.8,0.7,0.6,0.9,1.0,0.8,0.7, 0.6,0.5,0.9,0.8,0.7,0.6,0.5,0.4,0.3,0.2)
    float[] dp = array.from(187.5,422.3,145.6,98.2,53.4,312.8,76.1,220.5,165.9,88.7, 44.3,155.2,67.8,201.4,130.6,92.1,38.5,175.3,56.2,110.4, 84.7,43.2,198.6,72.3,145.8,63.1,29.4,88.5,112.3,55.7, 167.4,41.8,93.2,78.6,134.5,62.3,47.8,156.9,83.4,39.6)
    float[] dc = array.from(8.4,-5.1,6.2,-3.9,4.6,-0.1,3.7,-0.1,5.3,-0.2, 2.9,-0.1,3.1,-0.1,1.2,-0.1,0.5,-0.1,0.8,-0.05, 0.3,-0.1,0.1,-0.05,0.07,-0.02,0.09,-0.03,0.01,-0.08, 0.05,-0.01,0.02,-0.07,0.03,-0.09,0.06,-0.01,0.03,-0.05)
    for i = 0 to SIZE - 1
        array.set(spikeArr,i,array.get(ds,i))
        array.set(priceArr,i,array.get(dp,i))
        array.set(chgArr,i,array.get(dc,i))

// ─── SORT BY SPIKE RATIO (descending) ──────────────────────────────────────

for i = 0 to SIZE - 1
    array.set(idxArr, i, i)

for i = 0 to SIZE - 2
    int maxPos = i
    float maxVal = array.get(spikeArr, array.get(idxArr, i))
    for j = i + 1 to SIZE - 1
        float val = array.get(spikeArr, array.get(idxArr, j))
        if val > maxVal
            maxPos := j
            maxVal := val
    if maxPos != i
        int tmp = array.get(idxArr, i)
        array.set(idxArr, i, array.get(idxArr, maxPos))
        array.set(idxArr, maxPos, tmp)

// ─── SIGNAL LEVEL FUNCTIONS (6 levels: Orange > Yellow > Green > LtGreen > Blue > Pink) ─

// Level thresholds (spike ratio)
getLevel(float spike) =>
    spike >= 8.0 ? 1 : spike >= 5.0 ? 2 : spike >= 3.0 ? 3 : spike >= 2.0 ? 4 : spike >= 1.5 ? 5 : spike >= 1.2 ? 6 : 0

getLevelColor(int level) =>
    switch level
        1 => col1
        2 => col2
        3 => col3
        4 => col4
        5 => col5
        6 => col6
        => color.gray

getLevelLabel(int level) =>
    switch level
        1 => "ORANGE"
        2 => "YELLOW"
        3 => "GREEN"
        4 => "LT GRN"
        5 => "BLUE"
        6 => "PINK"
        => "—"

// Bright vs Dim: bright if |change%| >= priceMoveThr, dim otherwise
isBright(float changePct) =>
    math.abs(changePct) >= priceMoveThr

// Background color: bright = solid tint, dim = very faded tint
getSignalBg(int level, bool bright) =>
    color base = getLevelColor(level)
    if level == 0
        color.new(color.white, 0)
    else
        bright ? color.new(base, 75) : color.new(base, 92)

// Text color: bright = full color, dim = faded color
getSignalTxt(int level, bool bright) =>
    color base = getLevelColor(level)
    if level == 0
        color.gray
    else
        bright ? base : color.new(base, 50)

// ─── MARKET HOURS CHECK ─────────────────────────────────────────────────────

isInMarketHours() =>
    // Get current ET time
    h = hour(time, "America/New_York")
    m = minute(time, "America/New_York")
    mins = h * 60 + m
    openMins = 9 * 60 + 30   // 9:30 AM
    closeMins = 16 * 60       // 4:00 PM
    mins >= openMins and mins < closeMins

isAfterAlertDelay() =>
    h = hour(time, "America/New_York")
    m = minute(time, "America/New_York")
    mins = h * 60 + m
    openMins = 9 * 60 + 30
    mins >= (openMins + alertDelayMin)

bool mktOpen   = isInMarketHours()
bool pastDelay = isAfterAlertDelay()

// ─── BUILD TABLE ────────────────────────────────────────────────────────────

var table scannerTbl = table.new(tablePos, 7, tblRows + 1, border_width = tblBorder)

if barstate.islast
    // --- Header ---
    color hdrBg  = color.new(#e0e0e0, 0)
    color hdrTxt = color.new(#555555, 0)

    int col = 0
    if showRank
        table.cell(scannerTbl,col,0," # ",       text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_center)
        col += 1
    table.cell(scannerTbl,col,0," TICKER ",      text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_left)
    col += 1
    table.cell(scannerTbl,col,0," SPIKE ",       text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_center)
    col += 1
    table.cell(scannerTbl,col,0," SIGNAL ",      text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_center)
    col += 1
    if showPrice
        table.cell(scannerTbl,col,0," PRICE ",   text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_right)
        col += 1
    if showChg
        table.cell(scannerTbl,col,0," CHG% ",    text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_right)
        col += 1
    if showVol
        table.cell(scannerTbl,col,0," VOL ",     text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_right)

    // --- Data Rows ---
    int rowNum = 0
    for i = 0 to SIZE - 1
        if rowNum >= tblRows
            break

        int    idx   = array.get(idxArr, i)
        float  spike = array.get(spikeArr, idx)
        string name  = array.get(nameArr, idx)
        float  price = array.get(priceArr, idx)
        float  chg   = array.get(chgArr, idx)

        int    level  = getLevel(spike)
        bool   bright = isBright(chg)

        // Min volume filter: skip if no signal or filtered
        if not showNorm and level == 0
            continue

        int    row    = rowNum + 1
        color  bgCol  = getSignalBg(level, bright)
        color  sigTxt = getSignalTxt(level, bright)
        string sigLbl = getLevelLabel(level)
        // Append brightness indicator
        string brightInd = level > 0 ? (bright ? " *" : "") : ""
        color  chgCol = chg >= 0 ? color.new(#00c853,0) : color.new(#ff1744,0)
        string chgSign = chg >= 0 ? "+" : ""
        color  txtMain = color.new(#1a1a1a, 0)
        color  txtDim  = color.new(#888888, 0)

        int c = 0
        if showRank
            table.cell(scannerTbl,c,row," "+str.tostring(rowNum+1)+" ",                         text_color=txtDim, bgcolor=bgCol,text_size=txtSize,text_halign=text.align_center)
            c += 1
        table.cell(scannerTbl,c,row," "+name+" ",                                               text_color=txtMain,bgcolor=bgCol,text_size=txtSize,text_halign=text.align_left)
        c += 1
        table.cell(scannerTbl,c,row," "+str.tostring(spike,"#.#")+"x ",                         text_color=sigTxt, bgcolor=bgCol,text_size=txtSize,text_halign=text.align_center)
        c += 1
        table.cell(scannerTbl,c,row," "+sigLbl+brightInd+" ",                                   text_color=sigTxt, bgcolor=bgCol,text_size=txtSize,text_halign=text.align_center)
        c += 1
        if showPrice
            table.cell(scannerTbl,c,row," $"+str.tostring(price,"#.##")+" ",                    text_color=txtMain,bgcolor=bgCol,text_size=txtSize,text_halign=text.align_right)
            c += 1
        if showChg
            table.cell(scannerTbl,c,row," "+chgSign+str.tostring(chg,"#.##")+"% ",              text_color=chgCol, bgcolor=bgCol,text_size=txtSize,text_halign=text.align_right)
            c += 1
        if showVol
            table.cell(scannerTbl,c,row," "+str.tostring(spike * 1000,"#")+" ",                 text_color=txtDim, bgcolor=bgCol,text_size=txtSize,text_halign=text.align_right)

        rowNum += 1

// ─── ALERTS ─────────────────────────────────────────────────────────────────
// Orange (Level 1) and Yellow (Level 2) are the most noteworthy signals.
// Alert conditions respect: market hours, delay after open, bright-only filter.

bool canAlert = alertOn and (not alertMktHours or mktOpen) and (not alertMktHours or pastDelay)

bool orangeSpike = false
bool yellowSpike = false
bool anyTopSignal = false

for i = 0 to SIZE - 1
    float sp  = array.get(spikeArr, i)
    float chg = array.get(chgArr, i)
    int   lv  = getLevel(sp)
    bool  br  = isBright(chg)
    bool  passFilter = not alertBrightOnly or br

    if lv == 1 and passFilter
        orangeSpike := true
    if lv <= 2 and lv >= 1 and passFilter
        yellowSpike := true
    if lv >= 1 and lv <= 2 and passFilter
        anyTopSignal := true

// Alert: Orange signals (highest intensity)
alertcondition(canAlert and orangeSpike, title="ORANGE Signal (Highest)", message="ORANGE volume spike detected! Highest intensity — check scanner immediately.")

// Alert: Yellow signals (very high intensity)
alertcondition(canAlert and yellowSpike, title="YELLOW Signal (Very High)", message="YELLOW volume spike detected! Very high intensity — likely catalyst/news event.")

// Alert: Any top-2 signal (Orange or Yellow)
alertcondition(canAlert and anyTopSignal, title="Top Signal (Orange/Yellow)", message="Top-level volume spike detected (Orange or Yellow). Check scanner for details.")

plot(orangeSpike ? 1 : 0, display=display.none, title="Orange Flag")
plot(yellowSpike ? 1 : 0, display=display.none, title="Yellow Flag")
plot(anyTopSignal ? 1 : 0, display=display.none, title="Top Signal Flag")
