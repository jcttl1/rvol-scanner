// ─── DISPLAY NAMES (short ticker for table) ─────────────────────────────────

getName(string sym) =>
    // Strip exchange prefix for display
    string result = sym
    if str.contains(sym, ":")
        result := str.replace_all(str.substring(sym, str.pos(sym, ":") + 1), "USDT", "")
    result

string n01=getName(s01), string n02=getName(s02), string n03=getName(s03), string n04=getName(s04)
string n05=getName(s05), string n06=getName(s06), string n07=getName(s07), string n08=getName(s08)
string n09=getName(s09), string n10=getName(s10), string n11=getName(s11), string n12=getName(s12)
string n13=getName(s13), string n14=getName(s14), string n15=getName(s15), string n16=getName(s16)
string n17=getName(s17), string n18=getName(s18), string n19=getName(s19), string n20=getName(s20)
string n21=getName(s21), string n22=getName(s22), string n23=getName(s23), string n24=getName(s24)
string n25=getName(s25), string n26=getName(s26), string n27=getName(s27), string n28=getName(s28)
string n29=getName(s29), string n30=getName(s30), string n31=getName(s31), string n32=getName(s32)
string n33=getName(s33), string n34=getName(s34), string n35=getName(s35), string n36=getName(s36)
string n37=getName(s37), string n38=getName(s38), string n39=getName(s39), string n40=getName(s40)

// ─── DATA FETCH FUNCTION ────────────────────────────────────────────────────

getData() =>
    float avgVol     = ta.sma(volume, lookback)
    float spikeRatio = avgVol > 0 ? volume / avgVol : 0.0
    float changePct  = close[1] != 0 ? (close - close[1]) / close[1] * 100.0 : 0.0
    [spikeRatio, close, changePct]

// ─── REQUEST.SECURITY CALLS (40 tickers × 3 values = 120 tuple elements) ───

[sr01,c01,pc01] = request.security(s01, timeframe.period, getData())
[sr02,c02,pc02] = request.security(s02, timeframe.period, getData())
[sr03,c03,pc03] = request.security(s03, timeframe.period, getData())
