// ============================================================================
// RVOL Volume Spike Scanner
// TradingView Pine Script v6
//
// Inspired by Scripted Trading's Volume Spike Scanner. Scans up to 40 tickers
// for unusual volume spikes. Table cells light up with colored signals when
// spikes occur. 6 signal intensity levels with bright/dim distinction:
//   Bright = volume spike WITH a corresponding price move
//   Dim    = volume spike WITHOUT a significant price move
//
// 6 stock pre-load lists + separate crypto scanner. Continuously sorted with
// most intense spikes always at the top. Supports alerts with filters for
// market hours only, bright signals only, and delayed start after open.
//
// Add the indicator up to 6 times with different Table Numbers and Pre-Load
// Lists to scan 240 stocks simultaneously side-by-side.
// ============================================================================

//@version=6
indicator("RVOL Volume Spike Scanner", overlay = true, max_bars_back = 500)

// ─── INPUTS: SCANNER ────────────────────────────────────────────────────────

int    tableNum  = input.int(1, "Table Number", minval = 1, maxval = 6, tooltip = "Set a different number (1-6) for each instance of the indicator to position tables side-by-side without overlap.", group = "Scanner")
int    listNum   = input.int(1, "Pre-Load List #", minval = 1, maxval = 6, tooltip = "Which preset stock list to scan (1-6). Each list has 40 tickers. Set each indicator instance to a different list.", group = "Scanner")
int    lookback  = input.int(20, "Lookback Bars", minval = 5, maxval = 100, tooltip = "Number of prior bars to average volume over for spike detection. Recommended: 20.", group = "Scanner")
bool   showNorm  = input.bool(true, "Show Normal (no spike) Tickers", tooltip = "If off, only tickers with a signal are shown.", group = "Scanner")
bool   demoMode  = input.bool(false, "Demo Mode (Test Data)", tooltip = "Injects simulated data across all signal levels to verify colors and layout.", group = "Scanner")

// ─── INPUTS: FILTERS ────────────────────────────────────────────────────────

bool   useMinVol = input.bool(true, "Minimum Volume Filter", tooltip = "Filter out tickers with bar volume below the threshold. Recommended ON for stocks. Turn OFF for crypto.", group = "Filters")
int    minVolThr = input.int(10000, "Min Volume Threshold", minval = 0, step = 1000, tooltip = "Minimum bar volume required for a ticker to show a signal. Default 10,000.", group = "Filters")
float  priceMoveThr = input.float(0.3, "Price Move % (Bright/Dim)", minval = 0.05, step = 0.05, tooltip = "Minimum absolute % price change on the bar to classify a signal as BRIGHT (with price move). Below this = DIM (volume only, no significant price move).", group = "Filters")

// ─── INPUTS: ALERTS ─────────────────────────────────────────────────────────

bool   alertOn       = input.bool(true, "Enable Alerts", group = "Alerts")
bool   alertBrightOnly = input.bool(true, "Bright Signals Only", tooltip = "Only fire alerts for bright signals (volume spike WITH price move). On by default.", group = "Alerts")
bool   alertMktHours = input.bool(true, "Market Hours Only", tooltip = "Only fire alerts during market hours (9:30 AM - 4:00 PM ET). Prevents repeat alerts after close.", group = "Alerts")
int    alertDelayMin = input.int(0, "Start Alerts # Min After Open", minval = 0, maxval = 60, tooltip = "Keep alerts paused for this many minutes after market open. E.g. set to 7 to skip the first 7 minutes of chaos.", group = "Alerts")

// ─── INPUTS: TABLE APPEARANCE ───────────────────────────────────────────────

string textSz    = input.string("Tiny", "Text Size", options = ["Auto", "Tiny", "Small", "Normal", "Large", "Huge"], group = "Table Appearance")
int    tblRows   = input.int(40, "Max Rows", minval = 1, maxval = 40, group = "Table Appearance")
int    tblBorder = input.int(1, "Border Width", minval = 0, maxval = 3, group = "Table Appearance")
bool   showRank  = input.bool(true, "Show Rank (#)", group = "Table Appearance")
bool   showPrice = input.bool(true, "Show Price", group = "Table Appearance")
bool   showChg   = input.bool(true, "Show Change %", group = "Table Appearance")
bool   showVol   = input.bool(false, "Show Bar Volume", group = "Table Appearance")

// ─── INPUTS: SIGNAL COLORS (6 levels matching Scripted Trading) ─────────────

color  col1 = input.color(#ff8800, "Level 1 — Orange (Highest)",  group = "Signal Colors")
color  col2 = input.color(#ffdd00, "Level 2 — Yellow",            group = "Signal Colors")
color  col3 = input.color(#00cc44, "Level 3 — Green",             group = "Signal Colors")
color  col4 = input.color(#88ee88, "Level 4 — Light Green",       group = "Signal Colors")
color  col5 = input.color(#4488ff, "Level 5 — Blue",              group = "Signal Colors")
color  col6 = input.color(#dd66cc, "Level 6 — Pink (Lowest)",     group = "Signal Colors")

