bool L2 = listSel == "Tech & Growth"
bool L3 = listSel == "Momentum / Small Cap"
bool L4 = listSel == "Finance & REITs"
bool L5 = listSel == "Health & Biotech"
bool L6 = listSel == "Energy & Industrials"
bool L7 = listSel == "Crypto"

