// ─── COLLECT INTO ARRAYS ────────────────────────────────────────────────────

int SIZE = 40

var array<float>  spikeArr = array.new_float(SIZE, 0.0)
var array<float>  priceArr = array.new_float(SIZE, 0.0)
var array<float>  chgArr   = array.new_float(SIZE, 0.0)
var array<string> nameArr  = array.new_string(SIZE, "")
var array<int>    idxArr   = array.new_int(SIZE, 0)

// Fill arrays each bar
array.set(spikeArr, 0,  sr01), array.set(spikeArr, 1,  sr02), array.set(spikeArr, 2,  sr03), array.set(spikeArr, 3,  sr04)
array.set(spikeArr, 4,  sr05), array.set(spikeArr, 5,  sr06), array.set(spikeArr, 6,  sr07), array.set(spikeArr, 7,  sr08)
array.set(spikeArr, 8,  sr09), array.set(spikeArr, 9,  sr10), array.set(spikeArr, 10, sr11), array.set(spikeArr, 11, sr12)
