// ─── DISPLAY NAMES ──────────────────────────────────────────────────────────

getName(string sym) =>
    string result = sym
    if str.contains(sym, ":")
        result := str.substring(sym, str.pos(sym, ":") + 1)
    result

string n01=getName(s01),string n02=getName(s02),string n03=getName(s03),string n04=getName(s04)
