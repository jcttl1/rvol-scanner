// ─── RESOLVE TEXT SIZE ──────────────────────────────────────────────────────

var string txtSize = switch textSz
    "Auto"   => size.auto
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal
    "Large"  => size.large
    "Huge"   => size.huge
    => size.tiny

// ─── TABLE POSITION (based on Table Number for side-by-side) ────────────────
// Table 1 = top_right, 2 = top_center(?), etc. Pine only has 6 positions.
// Map table numbers to the 6 available positions.

var tablePos = switch tableNum
    1 => position.top_right
    2 => position.middle_right
    3 => position.bottom_right
    4 => position.top_left
    5 => position.middle_left
    6 => position.bottom_left
    => position.top_right

