// ─── SORT BY SPIKE RATIO (descending — selection sort) ──────────────────────

// Initialize index array
for i = 0 to SIZE - 1
    array.set(idxArr, i, i)

// Selection sort descending
for i = 0 to SIZE - 2
    int maxPos  = i
    float maxVal = array.get(spikeArr, array.get(idxArr, i))
    for j = i + 1 to SIZE - 1
        float val = array.get(spikeArr, array.get(idxArr, j))
        if val > maxVal
            maxPos := j
            maxVal := val
    if maxPos != i
        int tmp = array.get(idxArr, i)
        array.set(idxArr, i, array.get(idxArr, maxPos))
        array.set(idxArr, maxPos, tmp)

// ─── SIGNAL LEVEL FUNCTIONS ─────────────────────────────────────────────────

getSignalColor(float spike) =>
    spike >= 8.0 ? colExt : spike >= 5.0 ? colVHi : spike >= 3.0 ? colHi : spike >= 2.0 ? colElev : spike >= 1.5 ? colMod : color.gray

getSignalBg(float spike) =>
    spike >= 8.0 ? color.new(colExt, 80) : spike >= 5.0 ? color.new(colVHi, 82) : spike >= 3.0 ? color.new(colHi, 85) : spike >= 2.0 ? color.new(colElev, 87) : spike >= 1.5 ? color.new(colMod, 90) : color.new(color.gray, 95)

getSignalLabel(float spike) =>
    spike >= 8.0 ? "EXTREME" : spike >= 5.0 ? "VERY HIGH" : spike >= 3.0 ? "HIGH" : spike >= 2.0 ? "ELEVATED" : spike >= 1.5 ? "MODERATE" : "—"

// ─── TABLE POSITION ─────────────────────────────────────────────────────────

tablePos = switch tblPos
    "Top Right"     => position.top_right
    "Top Left"      => position.top_left
    "Bottom Right"  => position.bottom_right
    "Bottom Left"   => position.bottom_left
    "Middle Right"  => position.middle_right
    "Middle Left"   => position.middle_left
    => position.top_right

// ─── BUILD TABLE ────────────────────────────────────────────────────────────

var table scannerTbl = table.new(tablePos, 6, tblRows + 1, border_width = 1)

if barstate.islast
    // Header row
    color hdrBg  = color.new(#1a1d2b, 0)
    color hdrTxt = color.new(#8890a5, 0)

    table.cell(scannerTbl, 0, 0, "  #  ",    text_color = hdrTxt, bgcolor = hdrBg, text_size = size.tiny, text_halign = text.align_center)
    table.cell(scannerTbl, 1, 0, " TICKER ",  text_color = hdrTxt, bgcolor = hdrBg, text_size = size.tiny, text_halign = text.align_left)
    table.cell(scannerTbl, 2, 0, " SPIKE ",   text_color = hdrTxt, bgcolor = hdrBg, text_size = size.tiny, text_halign = text.align_center)
    table.cell(scannerTbl, 3, 0, " SIGNAL ",  text_color = hdrTxt, bgcolor = hdrBg, text_size = size.tiny, text_halign = text.align_center)
    table.cell(scannerTbl, 4, 0, " PRICE ",   text_color = hdrTxt, bgcolor = hdrBg, text_size = size.tiny, text_halign = text.align_right)
    table.cell(scannerTbl, 5, 0, "  CHG%  ",  text_color = hdrTxt, bgcolor = hdrBg, text_size = size.tiny, text_halign = text.align_right)

    // Data rows
    int rowNum = 0
    for i = 0 to SIZE - 1
        if rowNum >= tblRows
            break

        int    idx   = array.get(idxArr, i)
        float  spike = array.get(spikeArr, idx)
        string name  = array.get(nameArr, idx)
        float  price = array.get(priceArr, idx)
        float  chg   = array.get(chgArr, idx)

        // Skip normal tickers if user turned them off
        if not showNorm and spike < 1.5
            continue

        int    row     = rowNum + 1
        color  sigCol  = getSignalColor(spike)
        color  bgCol   = getSignalBg(spike)
        string sigLbl  = getSignalLabel(spike)
        color  chgCol  = chg >= 0 ? color.new(#00c853, 0) : color.new(#ff1744, 0)
        string chgSign = chg >= 0 ? "+" : ""
        color  rowBg   = color.new(#131620, 0)

        // Lit row background for signals
        color  cellBg  = spike >= 1.5 ? bgCol : rowBg

        table.cell(scannerTbl, 0, row, str.tostring(rowNum + 1),                       text_color = color.new(#555e70, 0), bgcolor = cellBg, text_size = size.tiny, text_halign = text.align_center)
        table.cell(scannerTbl, 1, row, " " + name + " ",                               text_color = color.new(#dfe2ea, 0), bgcolor = cellBg, text_size = size.tiny, text_halign = text.align_left)
        table.cell(scannerTbl, 2, row, " " + str.tostring(spike, "#.#") + "x ",        text_color = sigCol,                bgcolor = cellBg, text_size = size.tiny, text_halign = text.align_center)
        table.cell(scannerTbl, 3, row, " " + sigLbl + " ",                             text_color = sigCol,                bgcolor = cellBg, text_size = size.tiny, text_halign = text.align_center)
        table.cell(scannerTbl, 4, row, " $" + str.tostring(price, "#.##") + " ",       text_color = color.new(#dfe2ea, 0), bgcolor = cellBg, text_size = size.tiny, text_halign = text.align_right)
        table.cell(scannerTbl, 5, row, " " + chgSign + str.tostring(chg, "#.##") + "% ", text_color = chgCol,             bgcolor = cellBg, text_size = size.tiny, text_halign = text.align_right)

        rowNum += 1

// ─── ALERTS ─────────────────────────────────────────────────────────────────

// Fire alert when any ticker exceeds the alert threshold
bool anySpike = false
string alertMsg = ""

for i = 0 to SIZE - 1
    float sp = array.get(spikeArr, i)
    if sp >= alertThr
        anySpike := true
        alertMsg += array.get(nameArr, i) + " " + str.tostring(sp, "#.#") + "x | "

alertcondition(anySpike, title = "Volume Spike Detected", message = "RVOL Spike: {{plot_0}}")

// Plot hidden value for alert message
plot(anySpike ? array.max(spikeArr) : 0, display = display.none, title = "Max Spike")
