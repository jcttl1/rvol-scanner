// ============================================================================
// RVOL Scanner — Relative Volume Spike Scanner
// TradingView Pine Script v6
//
// Scans up to 40 tickers for unusual volume spikes on any timeframe.
// Table cells light up with colored signals by spike intensity.
// Continuously sorted — most intense spikes always at the top.
// 7 preset ticker lists (6 stock + 1 crypto) via dropdown selector.
// Custom symbol mode: override any/all slots with your own tickers.
// Add the indicator multiple times with different lists to scan 280 stocks
// and 40 cryptos simultaneously.
// ============================================================================

//@version=6
indicator("RVOL Scanner", overlay = true, max_bars_back = 500)

// ─── INPUTS: GENERAL ────────────────────────────────────────────────────────

string listSel  = input.string("Focus / Mega Cap", "Ticker List", options = ["Focus / Mega Cap", "Tech & Growth", "Momentum / Small Cap", "Finance & REITs", "Health & Biotech", "Energy & Industrials", "Crypto"], tooltip = "Select which preset list to scan. Add the indicator multiple times with different lists to scan all simultaneously.", group = "Scanner")
int    lookback = input.int(20, "Lookback Bars", minval = 5, maxval = 100, tooltip = "Number of prior bars to average volume over for spike detection.", group = "Scanner")
float  alertThr = input.float(3.0, "Alert Threshold", minval = 1.0, step = 0.5, tooltip = "Minimum spike ratio to trigger the general alert.", group = "Scanner")
bool   showNorm = input.bool(true, "Show Normal (no spike) Tickers", tooltip = "If off, only tickers with RVOL >= 1.5 are shown.", group = "Scanner")

// ─── INPUTS: ALERTS ─────────────────────────────────────────────────────────

bool   alertGeneral  = input.bool(true,  "Alert: Custom Threshold",   tooltip = "Fire alert when any ticker exceeds your Alert Threshold above.", group = "Alerts")
bool   alertVeryHigh = input.bool(true,  "Alert: Very High (5x+)",    tooltip = "Fire alert when any ticker hits VERY HIGH volume (5x+ spike). Great for catching catalyst moves early.", group = "Alerts")
bool   alertExtreme  = input.bool(true,  "Alert: Extreme (8x+)",      tooltip = "Fire alert when any ticker hits EXTREME volume (8x+ spike). Major event — get to this chart fast.", group = "Alerts")

// ─── INPUTS: TABLE APPEARANCE ───────────────────────────────────────────────

string tblPos   = input.string("Top Right", "Table Position", options = ["Top Right", "Top Left", "Bottom Right", "Bottom Left", "Middle Right", "Middle Left"], group = "Table Appearance")
string textSz   = input.string("Tiny", "Text Size", options = ["Auto", "Tiny", "Small", "Normal", "Large", "Huge"], tooltip = "Font size for all table text.", group = "Table Appearance")
int    tblRows  = input.int(40, "Max Rows", minval = 1, maxval = 40, tooltip = "Number of rows to display in table.", group = "Table Appearance")
int    colWidth = input.int(0, "Column Width (0 = auto)", minval = 0, maxval = 20, tooltip = "Fixed character width for columns. 0 uses auto-sizing.", group = "Table Appearance")
int    tblBorder = input.int(1, "Border Width", minval = 0, maxval = 3, group = "Table Appearance")
bool   showRank = input.bool(true, "Show Rank Column (#)", group = "Table Appearance")
bool   showPrice = input.bool(true, "Show Price Column", group = "Table Appearance")
bool   showChg  = input.bool(true, "Show Change % Column", group = "Table Appearance")

// ─── INPUTS: COLORS ─────────────────────────────────────────────────────────

color  colExt   = input.color(#ff0040, "Extreme (8x+)",   group = "Signal Colors")
color  colVHi   = input.color(#ff6600, "Very High (5x+)", group = "Signal Colors")
color  colHi    = input.color(#ffaa00, "High (3x+)",      group = "Signal Colors")
color  colElev  = input.color(#44bbff, "Elevated (2x+)",  group = "Signal Colors")
