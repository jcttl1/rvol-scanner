// ============================================================================
// RVOL Scanner — Relative Volume Spike Scanner
// TradingView Pine Script v6
//
// Scans up to 40 tickers for unusual volume spikes on any timeframe.
// Table cells light up with colored signals by spike intensity.
// Continuously sorted — most intense spikes always at the top.
// 7 preset ticker lists (6 stock + 1 crypto) via dropdown selector.
// Add the indicator multiple times with different lists to scan 280 stocks
// and 40 cryptos simultaneously.
// ============================================================================

//@version=6
indicator("RVOL Scanner", overlay = true, max_bars_back = 500)

// ─── INPUTS ─────────────────────────────────────────────────────────────────

string listSel = input.string("Focus / Mega Cap", "Ticker List", options = ["Focus / Mega Cap", "Tech & Growth", "Momentum / Small Cap", "Finance & REITs", "Health & Biotech", "Energy & Industrials", "Crypto"], tooltip = "Select which preset list to scan. Add the indicator multiple times with different lists to scan all simultaneously.")
int    lookback = input.int(20, "Lookback Bars", minval = 5, maxval = 100, tooltip = "Number of prior bars to average volume over for spike detection.")
string tblPos   = input.string("Top Right", "Table Position", options = ["Top Right", "Top Left", "Bottom Right", "Bottom Left", "Middle Right", "Middle Left"])
int    tblRows  = input.int(40, "Max Rows", minval = 5, maxval = 40, tooltip = "Number of rows to display in table.")
float  alertThr = input.float(3.0, "Alert Threshold", minval = 1.0, step = 0.5, tooltip = "Minimum spike ratio to trigger an alert.")
bool   showNorm = input.bool(true, "Show Normal (no spike) Tickers", tooltip = "If off, only tickers with RVOL >= 1.5 are shown.")
color  colExt   = input.color(#ff0040, "Extreme Color")
color  colVHi   = input.color(#ff6600, "Very High Color")
color  colHi    = input.color(#ffaa00, "High Color")
color  colElev  = input.color(#44bbff, "Elevated Color")
color  colMod   = input.color(#22ddaa, "Moderate Color")

// ─── LIST BOOLEANS ──────────────────────────────────────────────────────────

