// ============================================================================
// RVOL Crypto Volume Spike Scanner
// TradingView Pine Script v6
//
// Companion to the RVOL Volume Spike Scanner (stocks). Scans up to 40 crypto
// pairs for unusual volume spikes. Separated from stocks for performance
// reasons — crypto trades 24/7 with different volume profiles.
//
// Same signal system: 6 intensity levels, bright/dim distinction,
// continuous sorting, and alert support.
//
// Add the indicator alongside stock scanner instances. Uses its own table
// position to avoid overlap.
// ============================================================================

//@version=6
indicator("RVOL Crypto Volume Spike Scanner", overlay = true, max_bars_back = 500)

// ─── INPUTS: SCANNER ────────────────────────────────────────────────────────

int    tableNum  = input.int(1, "Table Number", minval = 1, maxval = 6, tooltip = "Set a different number (1-6) for each instance. Use a number that doesn't conflict with your stock scanner instances.", group = "Scanner")
int    listNum   = input.int(1, "Pre-Load List #", minval = 1, maxval = 3, tooltip = "Which preset crypto list to scan (1-3). Each list has 40 pairs.", group = "Scanner")
int    lookback  = input.int(20, "Lookback Bars", minval = 5, maxval = 100, tooltip = "Number of prior bars to average volume over for spike detection.", group = "Scanner")
bool   showNorm  = input.bool(true, "Show Normal (no spike) Tickers", tooltip = "If off, only tickers with a signal are shown.", group = "Scanner")
bool   demoMode  = input.bool(false, "Demo Mode (Test Data)", tooltip = "Injects simulated data to verify colors and layout.", group = "Scanner")

// ─── INPUTS: FILTERS ────────────────────────────────────────────────────────

float  priceMoveThr = input.float(0.5, "Price Move % (Bright/Dim)", minval = 0.05, step = 0.1, tooltip = "Minimum absolute % price change on the bar to classify a signal as BRIGHT. Higher default than stocks because crypto is more volatile.", group = "Filters")

// ─── INPUTS: ALERTS ─────────────────────────────────────────────────────────

bool   alertOn         = input.bool(true, "Enable Alerts", group = "Alerts")
bool   alertBrightOnly = input.bool(true, "Bright Signals Only", tooltip = "Only fire alerts for bright signals (volume spike WITH price move).", group = "Alerts")

// ─── INPUTS: TABLE APPEARANCE ───────────────────────────────────────────────

string textSz    = input.string("Tiny", "Text Size", options = ["Auto", "Tiny", "Small", "Normal", "Large", "Huge"], group = "Table Appearance")
int    tblRows   = input.int(40, "Max Rows", minval = 1, maxval = 40, group = "Table Appearance")
int    tblBorder = input.int(1, "Border Width", minval = 0, maxval = 3, group = "Table Appearance")
bool   showRank  = input.bool(true, "Show Rank (#)", group = "Table Appearance")
bool   showPrice = input.bool(true, "Show Price", group = "Table Appearance")
bool   showChg   = input.bool(true, "Show Change %", group = "Table Appearance")

// ─── INPUTS: SIGNAL COLORS ─────────────────────────────────────────────────

color  col1 = input.color(#ff8800, "Level 1 — Orange (Highest)",  group = "Signal Colors")
color  col2 = input.color(#ffdd00, "Level 2 — Yellow",            group = "Signal Colors")
color  col3 = input.color(#00cc44, "Level 3 — Green",             group = "Signal Colors")
color  col4 = input.color(#88ee88, "Level 4 — Light Green",       group = "Signal Colors")
color  col5 = input.color(#4488ff, "Level 5 — Blue",              group = "Signal Colors")
color  col6 = input.color(#dd66cc, "Level 6 — Pink (Lowest)",     group = "Signal Colors")

