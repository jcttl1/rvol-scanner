array.set(nameArr,4,n05),array.set(nameArr,5,n06),array.set(nameArr,6,n07),array.set(nameArr,7,n08)
array.set(nameArr,8,n09),array.set(nameArr,9,n10),array.set(nameArr,10,n11),array.set(nameArr,11,n12)
array.set(nameArr,12,n13),array.set(nameArr,13,n14),array.set(nameArr,14,n15),array.set(nameArr,15,n16)
array.set(nameArr,16,n17),array.set(nameArr,17,n18),array.set(nameArr,18,n19),array.set(nameArr,19,n20)
array.set(nameArr,20,n21),array.set(nameArr,21,n22),array.set(nameArr,22,n23),array.set(nameArr,23,n24)
array.set(nameArr,24,n25),array.set(nameArr,25,n26),array.set(nameArr,26,n27),array.set(nameArr,27,n28)
array.set(nameArr,28,n29),array.set(nameArr,29,n30),array.set(nameArr,30,n31),array.set(nameArr,31,n32)
array.set(nameArr,32,n33),array.set(nameArr,33,n34),array.set(nameArr,34,n35),array.set(nameArr,35,n36)
array.set(nameArr,36,n37),array.set(nameArr,37,n38),array.set(nameArr,38,n39),array.set(nameArr,39,n40)

// ─── DEMO MODE ──────────────────────────────────────────────────────────────

if demoMode
    float[] ds = array.from(14.2,10.5, 8.1,6.8,5.5, 4.7,4.2,3.6,3.3,3.0, 2.7,2.4,2.1,1.9,1.8, 1.6,1.5,1.4,1.3,1.2, 1.1,1.0,0.9,0.8,0.7,0.6,0.9,1.0,0.8,0.7, 0.6,0.5,0.9,0.8,0.7,0.6,0.5,0.4,0.3,0.2)
    float[] dp = array.from(67432.5,3422.3,312.6,148.2,0.534,0.312,1.76,0.0205,5.89,0.0000288, 44.3,22.52,0.678,1.014,0.306,0.0921,0.385,17.53,0.562,1.104, 8.47,0.432,0.0986,72.3,1.458,0.0631,0.294,0.885,1.123,0.557, 1.674,0.418,0.932,0.786,1.345,0.623,0.478,1.569,0.834,0.396)
    float[] dc = array.from(8.4,-5.1,6.2,-3.9,4.6,-0.1,3.7,-0.1,5.3,-0.2, 2.9,-0.1,3.1,-0.1,1.2,-0.1,0.5,-0.1,0.8,-0.05, 0.3,-0.1,0.1,-0.05,0.07,-0.02,0.09,-0.03,0.01,-0.08, 0.05,-0.01,0.02,-0.07,0.03,-0.09,0.06,-0.01,0.03,-0.05)
    for i = 0 to SIZE - 1
        array.set(spikeArr,i,array.get(ds,i))
        array.set(priceArr,i,array.get(dp,i))
        array.set(chgArr,i,array.get(dc,i))

// ─── SORT BY SPIKE RATIO (descending) ──────────────────────────────────────

for i = 0 to SIZE - 1
    array.set(idxArr, i, i)

for i = 0 to SIZE - 2
    int maxPos = i
    float maxVal = array.get(spikeArr, array.get(idxArr, i))
    for j = i + 1 to SIZE - 1
        float val = array.get(spikeArr, array.get(idxArr, j))
        if val > maxVal
            maxPos := j
            maxVal := val
    if maxPos != i
        int tmp = array.get(idxArr, i)
        array.set(idxArr, i, array.get(idxArr, maxPos))
        array.set(idxArr, maxPos, tmp)

// ─── SIGNAL LEVEL FUNCTIONS ─────────────────────────────────────────────────

getLevel(float spike) =>
    spike >= 8.0 ? 1 : spike >= 5.0 ? 2 : spike >= 3.0 ? 3 : spike >= 2.0 ? 4 : spike >= 1.5 ? 5 : spike >= 1.2 ? 6 : 0

getLevelColor(int level) =>
    switch level
        1 => col1
        2 => col2
        3 => col3
        4 => col4
        5 => col5
        6 => col6
        => color.gray

getLevelLabel(int level) =>
    switch level
        1 => "ORANGE"
        2 => "YELLOW"
        3 => "GREEN"
        4 => "LT GRN"
        5 => "BLUE"
        6 => "PINK"
        => "—"

isBright(float changePct) =>
    math.abs(changePct) >= priceMoveThr

getSignalBg(int level, bool bright) =>
    color base = getLevelColor(level)
    if level == 0
        color.new(color.white, 0)
    else
        bright ? color.new(base, 75) : color.new(base, 92)

getSignalTxt(int level, bool bright) =>
    color base = getLevelColor(level)
    if level == 0
        color.gray
    else
        bright ? base : color.new(base, 50)

// ─── FORMAT CRYPTO PRICE ────────────────────────────────────────────────────
// Crypto prices vary wildly ($67000 vs $0.00002). Smart formatting.

formatPrice(float p) =>
    p >= 1000 ? str.tostring(p, "#.#") : p >= 1 ? str.tostring(p, "#.##") : p >= 0.01 ? str.tostring(p, "#.####") : str.tostring(p, "#.########")

// ─── BUILD TABLE ────────────────────────────────────────────────────────────

var table scannerTbl = table.new(tablePos, 6, tblRows + 1, border_width = tblBorder)

if barstate.islast
    // --- Header ---
    color hdrBg  = color.new(#1a1d2b, 0)
    color hdrTxt = color.new(#8890a5, 0)

    int col = 0
    if showRank
        table.cell(scannerTbl,col,0," # ",       text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_center)
        col += 1
    table.cell(scannerTbl,col,0," PAIR ",        text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_left)
    col += 1
    table.cell(scannerTbl,col,0," SPIKE ",       text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_center)
    col += 1
    table.cell(scannerTbl,col,0," SIGNAL ",      text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_center)
    col += 1
    if showPrice
        table.cell(scannerTbl,col,0," PRICE ",   text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_right)
        col += 1
    if showChg
        table.cell(scannerTbl,col,0," CHG% ",    text_color=hdrTxt,bgcolor=hdrBg,text_size=txtSize,text_halign=text.align_right)

    // --- Data Rows ---
    int rowNum = 0
    for i = 0 to SIZE - 1
        if rowNum >= tblRows
            break

        int    idx   = array.get(idxArr, i)
        float  spike = array.get(spikeArr, idx)
        string name  = array.get(nameArr, idx)
        float  price = array.get(priceArr, idx)
        float  chg   = array.get(chgArr, idx)

        int    level  = getLevel(spike)
        bool   bright = isBright(chg)

        if not showNorm and level == 0
            continue

        int    row    = rowNum + 1
        color  bgCol  = getSignalBg(level, bright)
        color  sigTxt = getSignalTxt(level, bright)
        string sigLbl = getLevelLabel(level)
        string brightInd = level > 0 ? (bright ? " *" : "") : ""
        color  chgCol = chg >= 0 ? color.new(#00c853,0) : color.new(#ff1744,0)
        string chgSign = chg >= 0 ? "+" : ""
        // Dark theme text for crypto scanner
        color  txtMain = color.new(#dfe2ea, 0)
        color  txtDim  = color.new(#555e70, 0)

        // Default bg for no-signal rows in dark theme
        color  rowBg = level == 0 ? color.new(#131620, 0) : bgCol

        int c = 0
        if showRank
            table.cell(scannerTbl,c,row," "+str.tostring(rowNum+1)+" ",                       text_color=txtDim, bgcolor=rowBg,text_size=txtSize,text_halign=text.align_center)
            c += 1
        table.cell(scannerTbl,c,row," "+name+" ",                                             text_color=txtMain,bgcolor=rowBg,text_size=txtSize,text_halign=text.align_left)
        c += 1
        table.cell(scannerTbl,c,row," "+str.tostring(spike,"#.#")+"x ",                       text_color=sigTxt, bgcolor=rowBg,text_size=txtSize,text_halign=text.align_center)
        c += 1
        table.cell(scannerTbl,c,row," "+sigLbl+brightInd+" ",                                 text_color=sigTxt, bgcolor=rowBg,text_size=txtSize,text_halign=text.align_center)
        c += 1
        if showPrice
            table.cell(scannerTbl,c,row," $"+formatPrice(price)+" ",                          text_color=txtMain,bgcolor=rowBg,text_size=txtSize,text_halign=text.align_right)
            c += 1
        if showChg
            table.cell(scannerTbl,c,row," "+chgSign+str.tostring(chg,"#.##")+"% ",            text_color=chgCol, bgcolor=rowBg,text_size=txtSize,text_halign=text.align_right)

        rowNum += 1

// ─── ALERTS ─────────────────────────────────────────────────────────────────
// No market hours filter for crypto — it trades 24/7.

bool canAlert = alertOn

bool orangeSpike = false
bool yellowSpike = false
bool anyTopSignal = false

for i = 0 to SIZE - 1
    float sp  = array.get(spikeArr, i)
    float chg = array.get(chgArr, i)
    int   lv  = getLevel(sp)
    bool  br  = isBright(chg)
    bool  passFilter = not alertBrightOnly or br

    if lv == 1 and passFilter
        orangeSpike := true
    if lv <= 2 and lv >= 1 and passFilter
        yellowSpike := true
    if lv >= 1 and lv <= 2 and passFilter
        anyTopSignal := true

alertcondition(canAlert and orangeSpike, title="ORANGE Crypto Signal", message="ORANGE crypto volume spike detected! Extreme intensity — check scanner immediately.")
alertcondition(canAlert and yellowSpike, title="YELLOW Crypto Signal", message="YELLOW crypto volume spike detected! Very high intensity — likely major catalyst.")
alertcondition(canAlert and anyTopSignal, title="Top Crypto Signal", message="Top-level crypto volume spike detected (Orange or Yellow). Check scanner for details.")

plot(orangeSpike ? 1 : 0, display=display.none, title="Orange Flag")
plot(yellowSpike ? 1 : 0, display=display.none, title="Yellow Flag")
plot(anyTopSignal ? 1 : 0, display=display.none, title="Top Signal Flag")
