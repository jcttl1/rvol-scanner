// ─── DISPLAY NAMES ──────────────────────────────────────────────────────────

getName(string sym) =>
    string result = sym
    if str.contains(sym, ":")
        result := str.substring(sym, str.pos(sym, ":") + 1)
    // Strip trailing "USDT" for cleaner display
    if str.endswith(result, "USDT")
        result := str.substring(result, 0, str.length(result) - 4)
    result

